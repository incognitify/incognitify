{
  "name": "incognitify",
  "version": "0.0.0",
  "private": true,
  "description": "Mask sensitive data before sending to an LLM, rehydrate the response.",
  "author": "Arthur Silva <contact@arthursilva.com>",
  "homepage": "https://github.com/incognitify/incognitify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incognitify/incognitify.git"
  },
  "bugs": {
    "url": "https://github.com/incognitify/incognitify/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
