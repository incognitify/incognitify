# Postgres — host port 55432 matches docker-compose.yml (project-specific to avoid
# clashing with other local Postgres instances); Railway-managed in prod.
DATABASE_URL=postgres://postgres:postgres@localhost:55432/incognitify_cloud

# 32-byte master KEK (base64) used to wrap per-org DEKs. Keep in Railway secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KEK_BASE64=

# Better Auth — a long random secret (>= 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
PUBLIC_APP_URL=http://localhost:5173

# Production only (adapter-node behind a proxy like Railway): set ORIGIN to the public
# URL so SvelteKit form actions / CSRF work. PORT is provided by the host automatically.
# ORIGIN=https://incognitify.com

# Stripe — create a recurring per-seat Price for the Team plan and put its ID here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=

# Email over SMTP. Use Mailtrap now (Sandbox → SMTP Settings), swap to any provider later.
# Leave SMTP_HOST blank in dev to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=no-reply@incognitify.com
