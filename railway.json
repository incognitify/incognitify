{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/cloud/Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "node migrate.mjs",
    "startCommand": "node build",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
